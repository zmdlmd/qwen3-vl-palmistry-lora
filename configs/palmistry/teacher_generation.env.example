OPENAI_API_KEY="your_api_key"
# DASHSCOPE_API_KEY="your_dashscope_api_key"
TEACHER_API_BASE="https://api.openai.com/v1"
TEACHER_MODEL="gpt-4.1"
PALMISTRY_DATA_ROOT="/root/autodl-tmp/data/Palmistry.v2i.coco"

# DashScope Qwen3.5 multimodal example (API model IDs):
# TEACHER_API_BASE="https://dashscope.aliyuncs.com/compatible-mode/v1"
# TEACHER_MODEL="qwen-plus"
# TEACHER_MODEL="qwen-vl-plus"

TEACHER_MANIFEST="${PALMISTRY_DATA_ROOT}/manifests/teacher_all.jsonl"
TEACHER_IMAGE_DIR="${PALMISTRY_DATA_ROOT}"
TEACHER_OUTPUT_JSON="./artifacts/palmistry_llava.generated.json"
TEACHER_OUTPUT_JSONL="./artifacts/palmistry_teacher_generations.jsonl"

TEACHER_TEMPERATURE=0.2
TEACHER_MAX_TOKENS=2200
TEACHER_MAX_RETRIES=3
TEACHER_REQUEST_TIMEOUT=180
TEACHER_SLEEP_SECONDS=0.0
TEACHER_NUM_WORKERS=4
TEACHER_JSON_MODE=false

# Optional judge/filter stage. If enabled, the judge reviews each teacher JSON
# against the image and labels it as accept / accept_cautious / reject.
JUDGE_MODEL=""
JUDGE_TEMPERATURE=0.0
JUDGE_MAX_TOKENS=900
JUDGE_MIN_AVERAGE_SCORE=3.5
JUDGE_MIN_VISUAL_GROUNDING=3.0
JUDGE_MIN_UNCERTAINTY_HONESTY=3.0
JUDGE_REJECT_CAUTIOUS=false
