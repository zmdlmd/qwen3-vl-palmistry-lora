OPENAI_API_KEY="your_api_key"
# DASHSCOPE_API_KEY="your_dashscope_api_key"
TEACHER_API_BASE="https://api.openai.com/v1"
TEACHER_MODEL="gpt-4.1"
PALMISTRY_DATA_ROOT="/root/autodl-tmp/data/Palmistry.v2i.coco"

# DashScope Qwen3.5 multimodal example (API model IDs):
# TEACHER_API_BASE="https://dashscope.aliyuncs.com/compatible-mode/v1"
