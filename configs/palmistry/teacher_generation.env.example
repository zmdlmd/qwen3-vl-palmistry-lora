TEACHER_MANIFEST="${PALMISTRY_DATA_ROOT}/manifests/teacher_all.jsonl"
TEACHER_IMAGE_DIR="${PALMISTRY_DATA_ROOT}"
TEACHER_OUTPUT_JSON="./artifacts/palmistry_llava.generated.json"
TEACHER_OUTPUT_JSONL="./artifacts/palmistry_teacher_generations.jsonl"

TEACHER_TEMPERATURE=0.2
TEACHER_MAX_TOKENS=2200
TEACHER_MAX_RETRIES=3
TEACHER_REQUEST_TIMEOUT=180
TEACHER_SLEEP_SECONDS=0.0
TEACHER_JSON_MODE=false
