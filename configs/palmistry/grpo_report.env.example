BASE_MODEL_PATH="/path/to/Qwen3-VL-8B-Instruct"
# Prefer the structured GRPO adapter here if you already trained one.
LORA_WEIGHT_PATH="./output/palmistry_grpo_qwen3_vl_8b"
DATA_PATH="./artifacts/palmistry_llava.report_grpo.json"
IMAGE_FOLDER="./data/images"
OUTPUT_DIR="./output/palmistry_grpo_report_qwen3_vl_8b"

NUM_DEVICES=4
GLOBAL_BATCH_SIZE=4
BATCH_PER_DEVICE=1

LORA_ENABLE=true
LORA_RANK=32
LORA_ALPHA=32
LORA_DROPOUT=0.05
NUM_LORA_MODULES=-1

UNFREEZE_TOPK_LLM=1
UNFREEZE_TOPK_VISION=1
FREEZE_VISION_TOWER=true
FREEZE_LLM=true
FREEZE_MERGER=false
VISION_LORA=true

NUM_TRAIN_EPOCHS=1
LEARNING_RATE=5e-6
MERGER_LR=1e-5
VISION_LR=1e-6
WEIGHT_DECAY=0.1
WARMUP_RATIO=0.03
LOGGING_STEPS=1
DATALOADER_NUM_WORKERS=4

IMAGE_MIN_PIXELS=43904
IMAGE_MAX_PIXELS=43904
DEEPSPEED_CONFIG="./scripts/zero3.json"
REWARD_FUNCS_MODULE="src.palmistry.reward_funcs_report"
NUM_GENERATIONS=4
MAX_PROMPT_LENGTH=1024
MAX_COMPLETION_LENGTH=1400
